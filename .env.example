# Server
PORT=5000
NODE_ENV=development
# Comma-separated allowed origins (example: http://localhost:3000,https://your-frontend.vercel.app)
FRONTEND_ORIGIN=http://localhost:3000
# Set to 1 on proxy-based hosts (Render, Railway, etc.) for correct client IP handling
TRUST_PROXY=1

# MongoDB — local or Atlas URI
MONGO_URI=mongodb://localhost:27017/finance_dashboard

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_DAYS=7

# Seed admin credentials (used by npm run seed)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@1234
